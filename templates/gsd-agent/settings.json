{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.4-mini",
  "defaultThinkingLevel": "medium",
  "quietStartup": true,
  "collapseChangelog": true,
  "lastChangelogVersion": "2.33.1",
  "images": {
    "autoResize": true
  },
  "packages": [
    "git:github.com/hjanuschka/pi-multi-pass",
    "npm:pi-subagents",
    "npm:pi-lens",
    "npm:pi-simplify",
    "npm:@plannotator/pi-extension",
    "npm:@narumitw/pi-wait-what"
  ],
  "compactionThresholdOverride": 0.6,
  "taskIsolation": {
    "mode": "worktree"
  },
  "subagents": {
    "defaultModel": "openai-codex/gpt-5.4-mini",
    "agentOverrides": {
      "scout": {
        "model": "openai-codex/gpt-5.3-codex-spark",
        "thinking": "medium",
        "fallbackModels": [
          "openai-codex/gpt-5.4-mini",
          "claude-code/claude-haiku-4-5"
        ]
      },
      "worker": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium",
        "fallbackModels": [
          "openai-codex/gpt-5.3-codex-spark",
          "openai-codex/gpt-5.4"
        ]
      },
      "reviewer": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium",
        "fallbackModels": [
          "openai-codex/gpt-5.4",
          "claude-code/claude-sonnet-5"
        ]
      },
      "planner": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "xhigh",
        "fallbackModels": [
          "openai-codex/gpt-5.4",
          "claude-code/claude-opus-4-8",
          "claude-code/claude-sonnet-5"
        ]
      },
      "oracle": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "xhigh",
        "fallbackModels": [
          "openai-codex/gpt-5.4"
        ]
      },
      "researcher": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium",
        "fallbackModels": [
          "openai-codex/gpt-5.4"
        ]
      },
      "context-builder": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium",
        "fallbackModels": [
          "openai-codex/gpt-5.4"
        ]
      },
      "delegate": {
        "model": "openai-codex/gpt-5.4-mini",
        "thinking": "medium",
        "fallbackModels": [
          "openai-codex/gpt-5.4"
        ]
      }
    }
  },
  "autocompleteMaxVisible": 10,
  "doubleEscapeAction": "tree",
  "treeFilterMode": "all",
  "editorPaddingX": 0,
  "enabledModels": [
    "claude-code/claude-opus-4-8",
    "claude-code/claude-sonnet-5",
    "claude-code/claude-haiku-4-5",
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4-mini",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.3-codex-spark"
  ]
}